# Hoodsea frontend environment. Copy to .env.local and fill in real values.
# NEXT_PUBLIC_* vars are exposed to the browser; never put secrets you cannot
# afford to leak in them (Pinata JWT is client-visible by design here).

# ── Chain ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=4663
# Public Robinhood Chain RPC (default used if unset)
NEXT_PUBLIC_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# ── Site / API ────────────────────────────────────────────────────────────────
# Deployed site origin (no trailing slash). Used for OG metadata + share links.
NEXT_PUBLIC_SITE_URL=
# profileapi origin (RPC proxy /api/rpc, Irys uploads /api/irys/upload,
# profiles, airdrop oracle). Empty = same-origin.
NEXT_PUBLIC_PROFILE_API=
# Optional: marketing-landing hostname (e.g. example.com). Empty = app only.
NEXT_PUBLIC_LANDING_HOST=

# ── Wallet connect ────────────────────────────────────────────────────────────
# The app connects external wallets directly (browser-injected + Coinbase),
# no third-party auth dashboard required. WalletConnect is optional and only
# used for mobile wallets: set a project id from https://cloud.reown.com to
# enable it; leave empty to hide WalletConnect entirely.
NEXT_PUBLIC_WC_PROJECT_ID=

# ── Uniswap V4 infrastructure on Robinhood Chain ─────────────────────────────
NEXT_PUBLIC_POOL_MANAGER=0x8366a39cc670b4001a1121b8f6a443a643e40951
NEXT_PUBLIC_UNIVERSAL_ROUTER=0x8876789976decbfcbbbe364623c63652db8c0904
NEXT_PUBLIC_V4_QUOTER=0x8dc178efb8111bb0973dd9d722ebeff267c98f94
NEXT_PUBLIC_V4_STATE_VIEW=0xf3334192d15450cdd385c8b70e03f9a6bd9e673b
NEXT_PUBLIC_WETH=0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73
# Optional: USDC on Robinhood Chain (leave empty to hide USDC in the picker)
NEXT_PUBLIC_USDC=

# ── Hoodsea contracts (fill in after deploy) ─────────────────────────────────
NEXT_PUBLIC_LAUNCHPAD_ADDRESS=
NEXT_PUBLIC_TOKEN_FACTORY_ADDRESS=
NEXT_PUBLIC_FEE_HOOK_ADDRESS=
NEXT_PUBLIC_SWAP_ROUTER=
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_AIRDROP_DISTRIBUTOR=
# Permissionless airdrop campaigns contract
NEXT_PUBLIC_AIRDROP_ADDRESS=

# ── Storage fallback ──────────────────────────────────────────────────────────
# Pinata JWT used only if the server-side Irys endpoint is unreachable.
NEXT_PUBLIC_PINATA_JWT=

# ── Optional gates ────────────────────────────────────────────────────────────
# Unix ms timestamp for the public launch countdown gate (empty = open)
NEXT_PUBLIC_LAUNCH_TS=
# Key that bypasses the launch gate for previewing
NEXT_PUBLIC_PREVIEW_KEY=
