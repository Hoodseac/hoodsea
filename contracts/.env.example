# Hoodsea contracts — environment (copy to .env, never commit real values)

# Deployer key for --network robinhood
PRIVATE_KEY=0xyour_deployer_private_key

# Robinhood Chain RPC (chainId 4663). The public RPC is rate limited; use a keyed
# RPC if you have one.
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Blockscout verification (https://robinhoodchain.blockscout.com) accepts any
# non-empty string as the API key.
BLOCKSCOUT_API_KEY=blockscout

# Oracle role address (backend wallet, separate from the deployer/owner key)
MAINNET_ORACLE_ADDRESS=0xyour_oracle_address

# Used by ops scripts (scripts/setAirdropRoot.js, scripts/claimAirdrop.js,
# scripts/deployAirdrop.ts, scripts/redeployLaunchpad.ts, scripts/test*.ts)
# after a deploy — copy the values from deployment-robinhood.json.
AIRDROP_DISTRIBUTOR=
ORACLE_PRIVATE_KEY=
VAULT_ADDRESS=
TOKEN_FACTORY_ADDRESS=
LAUNCHPAD_ADDRESS=
SWAP_ROUTER=
FEE_HOOK=
POOL_MANAGER=0x8366a39cc670b4001a1121b8f6a443a643e40951
STATE_VIEW=0xf3334192d15450cdd385c8b70e03f9a6bd9e673b

# Uniswap V3 addresses for the ADDITIONAL plain (1% fee tier, no-hook) V3 pool seeded
# next to the V4 pool at bonding (chainId 4663, verified on-chain). deployFull.ts
# defaults to these; set here only to override. Clearing V3_FACTORY/V3_POSITION_MANAGER
# /WETH9 disables V3 seeding (V4-only). The pool uses the canonical 1% tier (tick
# spacing 200), matching Primehod's V3 graduation.
V3_FACTORY=0x1f7d7550B1b028f7571E69A784071F0205FD2EfA
V3_POSITION_MANAGER=0x73991a25c818bf1f1128deaab1492d45638de0d3
WETH9=0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73
# Optional V3 helpers (not used by deployFull.ts; handy for swap/quote scripts)
V3_SWAP_ROUTER02=0xcaf681a66d020601342297493863e78c959e5cb2
V3_QUOTER_V2=0x33e885ed0ec9bf04ecfb19341582aadcb4c8a9e7
# Token address used by the swap test scripts
TOKEN=
