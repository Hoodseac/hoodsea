# Hoodsea oracle — Robinhood Chain (chainId 4663). Copy to .env, never commit real values.

# Keyed RPC recommended; the public RPC (https://rpc.mainnet.chain.robinhood.com)
# is rate limited. RPC_URL is accepted as a fallback name.
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# getLogs tuning. Robinhood Chain (Arbitrum Orbit) blocks are MUCH faster than
# Base's 2s (sub-second possible), so the same wall-clock window needs a much
# larger block lookback than on Base.
LOOKBACK_BLOCKS=2000000
LOG_CHUNK=5000
RPC_DELAY_MS=150

# Oracle signer (submits merkle roots + executes epochs). Fresh key, not the owner.
ORACLE_PRIVATE_KEY=0xyour_oracle_private_key

# Deployed contract addresses (from contracts/deployment-robinhood.json)
VAULT_ADDRESS=
AIRDROP_DISTRIBUTOR=
LAUNCHPAD_ADDRESS=
TOKEN_FACTORY=
POOL_MANAGER=0x8366a39cc670b4001a1121b8f6a443a643e40951
FEE_HOOK=
SWAP_ROUTER=
# Canonical WETH on Robinhood Chain
WETH=0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73

# Stream-2 (0.1% trade-fee distribution)
STREAM2_ENABLED=1
STREAM2_MIN_ETH=0.00002
SLIPPAGE_BPS=500
DISTRIBUTE_MIN_ETH=0.000005

# Profile API (claim proofs are pushed here)
PROFILE_API=http://127.0.0.1:3001
AIRDROP_SECRET=shared_secret_matching_profileapi

# Optional, used by the helper bots (burn-exec.mjs, gen-volume.mjs, gen-vol-multi.mjs,
# pin-bot.mjs, stream2-fee.mjs)
EPOCH=0
TOKENS=
TOKEN=
SPLITTER=
WALLETS_FILE=../contracts/test-wallets.json
BUYERS=10,11,12,13,14
PER_ETH=0.03
SWAPS=2
BUY_ETH=0.003
WALLET_INDEX=45
IPFS_API=http://127.0.0.1:5001
PIN_TIMEOUT_MS=25000
PIN_INTERVAL_MS=900000
